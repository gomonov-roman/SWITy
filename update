// Конфигурация API
const API_KEY = 'b1325fa0'; // Твой API ключ (я использую тестовый, замени на свой)
const API_URL = 'https://www.omdbapi.com/';

// Функция поиска фильмов по жанру
async function searchMoviesByGenre(genre) {
    // Маппинг русских жанров на английские для API
    const genreMap = {
        'action': 'action',
        'comedy': 'comedy',
        'drama': 'drama',
        'horror': 'horror',
        'sci-fi': 'sci-fi',
        'fantasy': 'fantasy',
        'thriller': 'thriller',
        'romance': 'romance',
        'animation': 'animation',
        'mystery': 'mystery'
    };
    
    const englishGenre = genreMap[genre] || genre;
    
    // Показываем секцию результатов
    const searchResultsSection = document.getElementById('search-results');
    const moviesContainer = document.getElementById('movies-container');
    const resultsCountSpan = document.getElementById('results-count');
    
    searchResultsSection.style.display = 'block';
    moviesContainer.innerHTML = '<div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i> Загрузка фильмов...</div>';
    
    // Прокручиваем к результатам
    searchResultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    
    // Ищем фильмы по жанру (через поиск популярных фильмов)
    // OMDb API не имеет прямого поиска по жанру, поэтому используем разные поисковые запросы
    const searchQueries = [
        englishGenre,
        `${englishGenre} movie`,
        `best ${englishGenre} films`
    ];
    
    let allMovies = [];
    
    for (const query of searchQueries) {
        try {
            const response = await fetch(`${API_URL}?apikey=${API_KEY}&s=${encodeURIComponent(query)}&type=movie&page=1`);
            const data = await response.json();
            
            if (data.Search && data.Search.length > 0) {
                // Фильтруем результаты, чтобы оставить только те, у которых есть жанр
                for (const movie of data.Search) {
                    // Получаем детали фильма для проверки жанра
                    const detailsResponse = await fetch(`${API_URL}?apikey=${API_KEY}&i=${movie.imdbID}`);
                    const details = await detailsResponse.json();
                    
                    if (details.Genre && details.Genre.toLowerCase().includes(englishGenre)) {
                        if (!allMovies.some(m => m.imdbID === movie.imdbID)) {
                            movie.Genre = details.Genre;
                            movie.Plot = details.Plot;
                            allMovies.push(movie);
                        }
                    }
                }
            }
        } catch (error) {
            console.error(`Ошибка при поиске жанра ${genre}:`, error);
        }
        
        if (allMovies.length >= 20) break; // Достаточно 20 фильмов
    }
    
    // Убираем дубликаты
    allMovies = allMovies.filter((movie, index, self) => 
        index === self.findIndex(m => m.imdbID === movie.imdbID)
    );
    
    // Отображаем результаты
    if (allMovies.length > 0) {
        resultsCountSpan.innerHTML = `Найдено: ${allMovies.length}`;
        displayGenreMovies(allMovies, genre);
    } else {
        moviesContainer.innerHTML = `
            <div class="no-results">
                <i class="fas fa-tags"></i>
                <h3>Фильмы в жанре "${getGenreRussianName(genre)}" не найдены</h3>
                <p>Попробуйте выбрать другой жанр</p>
            </div>
        `;
    }
}

// Получение русского названия жанра
function getGenreRussianName(genre) {
    const names = {
        'action': 'Боевик',
        'comedy': 'Комедия',
        'drama': 'Драма',
        'horror': 'Ужасы',
        'sci-fi': 'Фантастика',
        'fantasy': 'Фэнтези',
        'thriller': 'Триллер',
        'romance': 'Романтика',
        'animation': 'Мультфильм',
        'mystery': 'Детектив'
    };
    return names[genre] || genre;
}

// Отображение фильмов по жанру
function displayGenreMovies(movies, genre) {
    const moviesContainer = document.getElementById('movies-container');
    const sectionHeader = document.querySelector('#search-results .section-header h2');
    
    sectionHeader.innerHTML = `<i class="fas fa-tags"></i> Фильмы в жанре: ${getGenreRussianName(genre)}`;
    
    moviesContainer.innerHTML = movies.map(movie => `
        <div class="movie-card" data-id="${movie.imdbID}">
            <div class="movie-poster">
                <img src="${movie.Poster !== 'N/A' ? movie.Poster : 'https://via.placeholder.com/300x450?text=No+Poster'}" 
                     alt="${movie.Title}">
                <div class="movie-overlay">
                    <button class="view-details-btn" data-id="${movie.imdbID}">
                        <i class="fas fa-info-circle"></i> Подробнее
                    </button>
                </div>
            </div>
            <div class="movie-info">
                <h3 class="movie-title">${movie.Title}</h3>
                <div class="movie-year">📅 ${movie.Year}</div>
                <div class="movie-type">${movie.Type === 'movie' ? '🎬 Фильм' : '📺 Сериал'}</div>
                ${movie.Genre ? `<div class="movie-genre">🎭 ${movie.Genre.split(',')[0]}</div>` : ''}
            </div>
        </div>
    `).join('');
    
    // Добавляем обработчики для карточек фильмов
    document.querySelectorAll('.movie-card').forEach(card => {
        card.addEventListener('click', (e) => {
            const movieId = card.dataset.id;
            if (movieId) {
                window.location.href = `movie-details.html?id=${movieId}`;
            }
        });
    });
    
    document.querySelectorAll('.view-details-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const movieId = btn.dataset.id;
            if (movieId) {
                window.location.href = `movie-details.html?id=${movieId}`;
            }
        });
    });
}

// Инициализация кнопок жанров
function initGenreButtons() {
    const genreButtons = document.querySelectorAll('.genre-btn');
    
    genreButtons.forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const genre = btn.dataset.genre;
            
            // Добавляем активный класс
            genreButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            // Загружаем фильмы по жанру
            await searchMoviesByGenre(genre);
        });
    });
}

