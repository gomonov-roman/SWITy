    color: #b0b0b0;
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }
  
  .video-stats {
    display: flex;
    gap: 2rem;
    color: #888;
  }
  
  .video-stats span {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .video-stats i {
    color: #ff0000;
  }
  
  /* Кнопки действий */
  .trailer-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 25px;
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    color: #e0e0e0;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 500;
    transition: all 0.3s;
  }
  
  .action-btn:hover {
    background: rgba(255, 0, 0, 0.1);
    border-color: #ff0000;
    transform: translateY(-3px);
    color: #fff;
  }
  
  .action-btn.primary {
    background: #ff0000;
    border-color: #ff0000;
    color: white;
    font-weight: 600;
  }
  
  .action-btn.primary:hover {
    background: #cc0000;
    border-color: #cc0000;
  }
  
  /* Сетка предложений */
  .suggestion-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin: 1.5rem 0 3rem;
  }
  
  .suggestion-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s;
    display: block;
  }
  
  .suggestion-card:hover {
    background: rgba(255, 0, 0, 0.1);
    border-color: #ff0000;
    transform: translateY(-5px);
  }
  
  .suggestion-icon {
    width: 50px;
    height: 50px;
    background: rgba(255, 0, 0, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  
  .suggestion-icon i {
    font-size: 1.5rem;
    color: #ff0000;
  }
  
  .suggestion-card h4 {
    color: #fff;
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  
  .suggestion-card p {
    color: #b0b0b0;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
  }
  
  /* Советы */
  .youtube-tips {
    background: rgba(255, 215, 0, 0.05);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 15px;
    padding: 2rem;
    margin-top: 2rem;
  }
  
  .youtube-tips h3 {
    color: #ffd700;
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  
  .tips-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  
  .tip {
    display: flex;
    align-items: flex-start;
    gap: 15px;
  }
  
  .tip-number {
    background: #ffd700;
    color: #000;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    flex-shrink: 0;
    font-size: 1rem;
  }
  
  .tip p {
    color: #e0e0e0;
    margin: 0;
    line-height: 1.5;
  }
  
  /* ===== АДАПТИВНОСТЬ ===== */
  @media (max-width: 900px) {
    .trailer-preview {
        flex-direction: column;
        text-align: center;
    }
    
    .preview-image {
        width: 100%;
        max-width: 500px;
    }
    
    .youtube-thumbnail {
        height: 250px;
    }
    
    .video-stats {
        justify-content: center;
    }
  }
  
  @media (max-width: 600px) {
    .trailer-actions {
        flex-direction: column;
    }
    
    .action-btn {
        justify-content: center;
        text-align: center;
    }
    
    .suggestion-grid {
        grid-template-columns: 1fr;
    }
    
    .tips-list {
        grid-template-columns: 1fr;
    }
  }
   

  /* Стили для актёров */
.actors-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.actor-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px;
    background: #f0f0f0;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
}

.actor-item:hover {
    background: #e0e0e0;
    transform: translateY(-2px);
}

/* Стили для всплывающей карточки с фото */
.actor-tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 10px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    padding: 10px;
    z-index: 1000;
    min-width: 120px;
    text-align: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    pointer-events: none;
}

.actor-item:hover .actor-tooltip {
    opacity: 1;
    visibility: visible;
    bottom: calc(100% + 10px);
}

.actor-tooltip img {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 50%;
    margin-bottom: 8px;
    border: 3px solid #ffd700;
}

.actor-tooltip .actor-name {
    font-weight: bold;
    font-size: 12px;
    color: #333;
    margin-top: 5px;
}

/* Стрелочка подсказки */
.actor-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 6px;
    border-style: solid;
    border-color: white transparent transparent transparent;
}




/* Стили для активной кнопки жанра */
.genre-btn.active {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    transform: scale(1.05);
    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
}

/* Анимация загрузки */
.loading-spinner {
    text-align: center;
    padding: 40px;
    font-size: 20px;
    color: #667eea;
}

.loading-spinner i {
    margin-right: 10px;
}

/* Сообщение об информации */
.info-message {
    text-align: center;
    padding: 40px;
    background: #f8f9fa;
    border-radius: 12px;
    margin: 20px;
}

.info-message i {
    font-size: 48px;
    color: #667eea;
    margin-bottom: 15px;
}

.info-message h3 {
    margin-bottom: 10px;
    color: #333;
}

.info-message p {
    color: #666;
    margin: 5px 0;
}

.test-btn {
    margin-top: 15px;
    padding: 10px 20px;
    background: #667eea;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s;
}

.test-btn:hover {
    background: #764ba2;
    transform: translateY(-2px);
}

/* Результаты поиска */
.no-results {
    text-align: center;
    padding: 40px;
    color: #666;
}

.no-results i {
    font-size: 48px;
    margin-bottom: 15px;
    color: #999;
}






















































































































































































































































