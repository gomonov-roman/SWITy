/* МАКСИМАЛЬНО УНИВЕРСАЛЬНЫЙ КОД - центрирует всё подряд */
.movie-card *,
.film-card *,
[class*="movie"] *,
[class*="film"] * {
    text-align: center;
}

.movie-card .movie-info,
.movie-card .film-info,
.movie-card > div > div {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.movie-card h3,
.movie-card p,
.movie-card span,
.movie-card div:not(.movie-poster):not(.film-poster) {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
}

/* Специально для года и жанра */
.movie-card [class*="year"],
.movie-card [class*="genre"],
.movie-card [class*="meta"] {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    gap: 10px;
}
























/* ===== СТИЛИ ДЛЯ СТРАНИЦЫ ДЕТАЛЕЙ ФИЛЬМА ===== */

/* Основной контейнер страницы деталей */
.movie-details {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
}

/* Контейнер с постером и информацией */
.details-container {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    background: rgba(30, 35, 45, 0.7);
    border-radius: 20px;
    padding: 30px;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 215, 0, 0.1);
}

/* Секция с постером */
.poster-section {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.detail-poster {
    width: 100%;
    max-width: 300px;
    height: auto;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    border: 2px solid rgba(255, 215, 0, 0.2);
    transition: transform 0.3s;
}

.detail-poster:hover {
    transform: scale(1.02);
    border-color: rgba(255, 215, 0, 0.5);
}

/* Мета-информация под постером */
.movie-meta {
    width: 100%;
    margin-top: 20px;
    text-align: center;
}

.movie-meta > div {
    margin: 10px 0;
    padding: 8px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    border-left: 3px solid #ffd700;
}

.rating {
    font-size: 1.2rem;
    color: #ffd700;
}

.year, .genre, .runtime {
    font-size: 1rem;
    color: #e0e0e0;
}

/* Секция с информацией */
.info-section {
    flex: 1;
}

.overview {
    margin-bottom: 30px;
}

.overview h2 {
    color: #ffd700;
    font-size: 1.8rem;
    margin-bottom: 15px;
    border-bottom: 2px solid rgba(255, 215, 0, 0.3);
    padding-bottom: 10px;
}

#detail-overview {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #e0e0e0;
    background: rgba(255, 255, 255, 0.03);
    padding: 20px;
    border-radius: 12px;
}

/* Сетка деталей */
.details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.detail-item {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 15px;
    border-left: 4px solid #ffd700;
    transition: transform 0.3s;
}

.detail-item:hover {
    transform: translateY(-5px);
    background: rgba(255, 215, 0, 0.1);
}

.detail-item h3 {
    color: #ffd700;
    margin-bottom: 10px;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    gap: 8px;
}

.detail-item p {
    color: #e0e0e0;
    line-height: 1.6;
    font-size: 0.95rem;
}

/* Кнопка "Назад" */
.back-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #ffd700;
    text-decoration: none;
    font-size: 1.1rem;
    padding: 10px 20px;
    background: rgba(255, 215, 0, 0.1);
    border-radius: 8px;
    border: 1px solid rgba(255, 215, 0, 0.3);
    margin-bottom: 20px;
    transition: all 0.3s;
}

.back-button:hover {
    background: rgba(255, 215, 0, 0.2);
    transform: translateX(-5px);
}

/* Заголовок фильма */
#movie-title {
    color: #ffd700;
    font-size: 2.5rem;
    margin-bottom: 30px;
    text-align: center;
    text-shadow: 0 2px 10px rgba(255, 215, 0, 0.3);
}

/* ===== СТИЛИ ДЛЯ ТРЕЙЛЕРОВ НА СТРАНИЦЕ ДЕТАЛЕЙ ===== */

/* Переопределяем стили для trailer-section на странице деталей */
.movie-details .trailer-section {
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 20px;
}

.movie-details #trailer-container {
    background: rgba(30, 35, 45, 0.7);
    border-radius: 20px;
    padding: 30px;
    border: 1px solid rgba(255, 0, 0, 0.3);
    max-width: 1000px;
    margin: 0 auto;
}

/* Специальные стили для поисковой строки на странице деталей */
.movie-details .trailer-search {
    margin-bottom: 30px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
}

.movie-details .search-box {
    display: flex;
    gap: 10px;
    background: rgba(255, 255, 255, 0.08);
    border: 2px solid rgba(255, 215, 0, 0.3);
    border-radius: 15px;
    padding: 5px;
    max-width: 800px;
    margin: 0 auto;
}

.movie-details #trailer-search-input {
    flex: 1;
    padding: 15px 20px;
    background: transparent;
    border: none;
    color: #fff;
    font-size: 1rem;
    outline: none;
}

.movie-details #search-trailer-btn {
    padding: 15px 30px;
    background: linear-gradient(135deg, #ff0000 0%, #cc0000 100%);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
}

/* Центрируем видео-рекомендации */
.movie-details .video-suggestions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
    max-width: 900px;
    margin: 20px auto;
}

.movie-details .video-suggestion {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 15px;
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    color: #e0e0e0;
    cursor: pointer;
    transition: all 0.3s;
}

/* Центрируем заголовки */
.movie-details .trailer-section h2,
.movie-details .recommended-videos h3 {
    text-align: center;
}

/* Центрируем ссылку на YouTube */
.movie-details .youtube-direct-link {
    text-align: center;
    margin-top: 30px;
}

/* ===== АДАПТИВНОСТЬ ДЛЯ СТРАНИЦЫ ДЕТАЛЕЙ ===== */
@media (max-width: 768px) {
    .details-container {
        grid-template-columns: 1fr;
        padding: 20px;
    }
    
    .poster-section {
        max-width: 300px;
        margin: 0 auto;
    }
    
    .detail-poster {
        max-width: 250px;
    }
    
    #movie-title {
        font-size: 2rem;
    }
    
    .movie-details .search-box {
        flex-direction: column;
    }
    
    .movie-details #search-trailer-btn {
        width: 100%;
    }
    
    .movie-details .video-suggestions {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 480px) {
    .details-grid {
        grid-template-columns: 1fr;
    }
    
    #movie-title {
        font-size: 1.5rem;
    }
}

